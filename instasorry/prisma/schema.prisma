generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  subscription         Subscription?
  instagramAccount     InstagramAccount?
  notificationPrefs    NotificationPreference?
  payments             Payment[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 String    // "MONTHLY" | "ANNUAL"
  status               String    @default("TRIALING") // "TRIALING" | "ACTIVE" | "PAST_DUE" | "CANCELED" | "UNPAID"
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  stripeCustomerId     String?
  mpSubscriptionId     String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  currency      String   @default("BRL")
  status        String   // "PENDING" | "APPROVED" | "FAILED" | "REFUNDED"
  provider      String
  externalId    String?  @unique
  description   String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model InstagramAccount {
  id              String    @id @default(cuid())
  userId          String    @unique
  instagramId     String?
  username        String
  profilePicUrl   String?
  fullName        String?
  followerCount   Int?
  followingCount  Int?
  lastSyncAt      DateTime?
  syncEnabled     Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots InstagramSnapshot[]
  events    InstagramEvent[]

  @@map("instagram_accounts")
}

model InstagramSnapshot {
  id                 String   @id @default(cuid())
  instagramAccountId String
  takenAt            DateTime @default(now())
  followerCount      Int
  followingCount     Int
  sourceType         String   @default("upload")

  instagramAccount InstagramAccount    @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)
  followers        InstagramFollower[]
  following        InstagramFollowing[]

  @@map("instagram_snapshots")
}

model InstagramFollower {
  id          String   @id @default(cuid())
  snapshotId  String
  username    String
  fullName    String?
  profileUrl  String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  snapshot InstagramSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, username])
  @@index([snapshotId])
  @@map("instagram_followers")
}

model InstagramFollowing {
  id          String   @id @default(cuid())
  snapshotId  String
  username    String
  fullName    String?
  profileUrl  String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  snapshot InstagramSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, username])
  @@index([snapshotId])
  @@map("instagram_following")
}

model InstagramEvent {
  id                 String   @id @default(cuid())
  instagramAccountId String
  eventType          String   // "UNFOLLOWED" | "NEW_FOLLOWER" | "STARTED_FOLLOWING" | "STOPPED_FOLLOWING"
  targetUsername     String
  targetFullName     String?
  targetProfileUrl   String?
  detectedAt         DateTime @default(now())
  notified           Boolean  @default(false)
  notifiedAt         DateTime?

  instagramAccount InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  @@unique([instagramAccountId, targetUsername, eventType, detectedAt])
  @@index([instagramAccountId, eventType])
  @@map("instagram_events")
}

model NotificationPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  emailEnabled      Boolean  @default(true)
  pushEnabled       Boolean  @default(true)
  unfollowAlert     Boolean  @default(true)
  newFollowerAlert  Boolean  @default(true)
  weeklyDigest      Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
